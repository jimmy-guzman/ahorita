{
  "name": "@ahorita/backend",
  "type": "module",
  "exports": {
    ".": "./src/index.ts"
  },
  "scripts": {
    "clean": "rimraf .turbo node_modules dist",
    "db:push": "dotenv-run -- drizzle-kit push",
    "db:studio": "dotenv-run -- drizzle-kit studio",
    "dev": "dotenv-run -- bun run --hot src/index.ts",
    "format": "biome format .",
    "format:fix": "biome format --write .",
    "lint": "biome lint .",
    "lint:fix": "biome lint --write .",
    "preview": "NODE_ENV=production dotenv-run -- bun run ./src/index.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@better-auth/drizzle-adapter": "1.6.16",
    "@elysiajs/cors": "1.4.2",
    "@elysiajs/openapi": "1.4.15",
    "@elysiajs/opentelemetry": "1.4.11",
    "@libsql/client": "0.17.3",
    "@openrouter/ai-sdk-provider": "2.9.1",
    "@opentelemetry/exporter-trace-otlp-proto": "0.219.0",
    "@opentelemetry/sdk-trace-node": "2.8.0",
    "ai": "6.0.202",
    "better-auth": "1.6.16",
    "drizzle-orm": "0.45.2",
    "drizzle-typebox": "0.3.3",
    "elysia": "1.4.28",
    "env-schema": "7.0.0",
    "nanoid": "5.1.11",
    "picocolors": "1.1.1",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "drizzle-kit": "0.31.10",
    "rimraf": "6.1.3",
    "typescript": "6.0.3"
  }
}
