# shellcheck disable=SC2034,SC2148
NODE_ENV=development
BUN_CONFIG_NO_CLEAR_TERMINAL_ON_RELOAD=true

QUERY_LOGGING=false

DATABASE_URL="file:ahorita.db" # Or libsql://DATABASE for Turso

TURSO_AUTH_TOKEN="token"

AXIOM_TOKEN="token"
AXIOM_DATASET="dataset"

VITE_OTEL_DASHBOARD=""
VITE_SERVER_DOMAIN=http://localhost:3000

# OpenRouter — https://openrouter.ai/settings/keys
OPENROUTER_API_KEY=
# Optional model overrides (OpenRouter slugs)
# CHAT_ORCHESTRATOR_MODEL=anthropic/claude-sonnet-4.6
# CHAT_SPECIALIST_MODEL=anthropic/claude-haiku-4.5

# Better Auth — generate a secret with: openssl rand -base64 32
BETTER_AUTH_SECRET=
BETTER_AUTH_URL=http://localhost:3000
CORS_ORIGIN=http://localhost:5173
