{
  "name": "@ahorita/frontend",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "NODE_ENV=production dotenv-run -- vite build",
    "clean": "rimraf .turbo node_modules dist coverage",
    "coverage": "dotenv-run -- vitest run --coverage",
    "dev": "dotenv-run -- bunx --bun vite",
    "e2e": "playwright test",
    "format": "biome format .",
    "format:fix": "biome format --write .",
    "lint": "biome lint .",
    "lint:fix": "biome lint --write .",
    "preview": "dotenv-run -- vite preview",
    "test": "dotenv-run -- vitest",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@ai-sdk/react": "3.0.204",
    "@elysiajs/eden": "1.4.9",
    "@hookform/resolvers": "5.4.0",
    "@iconify/react": "6.0.2",
    "@tanstack/react-query": "5.101.0",
    "@tanstack/react-router": "1.170.15",
    "@tanstack/react-table": "8.21.3",
    "ai": "6.0.202",
    "better-auth": "1.6.16",
    "clsx": "2.1.1",
    "date-fns": "4.4.0",
    "holy-loader": "2.3.14",
    "lucide-react": "1.17.0",
    "radix-ui": "1.5.0",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "react-hook-form": "7.78.0",
    "recharts": "3.8.1",
    "sonner": "2.0.7",
    "streamdown": "2.5.0",
    "tailwind-merge": "3.6.0",
    "valibot": "1.4.1",
    "zustand": "5.0.14"
  },
  "devDependencies": {
    "@ahorita/backend": "workspace:*",
    "@playwright/test": "1.60.0",
    "@tailwindcss/typography": "0.5.20",
    "@tailwindcss/vite": "4.3.0",
    "@tanstack/react-devtools": "0.10.5",
    "@tanstack/react-query-devtools": "5.101.0",
    "@tanstack/react-router-devtools": "1.167.0",
    "@tanstack/router-vite-plugin": "1.167.18",
    "@testing-library/jest-dom": "6.9.1",
    "@testing-library/react": "16.3.2",
    "@testing-library/user-event": "14.6.1",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.2",
    "@vitest/coverage-v8": "4.1.8",
    "daisyui": "5.5.23",
    "happy-dom": "20.10.2",
    "msw": "2.14.6",
    "rimraf": "6.1.3",
    "tailwindcss": "4.3.0",
    "typescript": "6.0.3",
    "vite": "8.0.16",
    "vitest": "4.1.8"
  }
